# Python 예시 Dockerfile
FROM python:3.11-slim

# FFmpeg 설치
RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 애플리케이션 코드 복사
COPY app.py .

# 포트 설정 (Cloud Run이 PORT 환경 변수를 사용)
ENV PORT=8080

# 애플리케이션 실행
CMD ["python", "app.py"]






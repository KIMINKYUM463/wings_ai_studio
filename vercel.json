{
  "functions": {
    "app/api/ai/render/route.ts": {
      "maxDuration": 300
    },
    "app/api/upload-to-gcs/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
